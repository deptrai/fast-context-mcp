# Test environment configuration
# Copy to .env and fill in values for integration tests

# Windsurf API key (auto-discovered if Windsurf is installed)
WINDSURF_API_KEY=

# Deep search API key (required for deep mode integration tests)
DEEPGREP_API_KEY=
DEEPGREP_API_URL=https://router.chainlens.net/v1
DEEPGREP_MODEL=deep-search

# Cache control
FC_CACHE_DISABLED=false
FC_CACHE_TTL_MS=300000
FC_CACHE_MAX_ENTRIES=100

# Snippet control
FC_SNIPPET_MAX_LINES=200
FC_LINE_MAX_CHARS=500

# Network
FC_TIMEOUT_MS=30000
FC_ALLOW_INSECURE_TLS=0
