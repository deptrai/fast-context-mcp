{
  "name": "@sammysnake/fast-context-mcp",
  "version": "1.3.0",
  "description": "AI-driven semantic code search via reverse-engineered Windsurf protocol (Node.js)",
  "type": "module",
  "main": "deepgrep/src/server.mjs",
  "bin": {
    "fast-context-mcp": "deepgrep/src/server.mjs"
  },
  "files": [
    "deepgrep/src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node deepgrep/src/server.mjs",
    "test": "node --test 'test/**/*.test.mjs'",
    "test:unit": "node --test 'test/*.test.mjs'",
    "test:ci": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=junit --test-reporter-destination=test-results.xml 'test/**/*.test.mjs'"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SammySnake-d/fast-context-mcp.git"
  },
  "homepage": "https://github.com/SammySnake-d/fast-context-mcp#readme",
  "bugs": {
    "url": "https://github.com/SammySnake-d/fast-context-mcp/issues"
  },
  "keywords": [
    "mcp",
    "code-search",
    "semantic-search",
    "windsurf",
    "devstral",
    "ripgrep",
    "claude",
    "ai"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@vscode/ripgrep": "^1.15.9",
    "sql.js": "^1.14.0",
    "tree-node-cli": "^1.6.0",
    "zod": "^3.25.0"
  },
  "license": "MIT"
}
